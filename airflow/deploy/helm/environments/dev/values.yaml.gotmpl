ingress:
  enabled: true
  annotations:
    kubernetes.io/ingress.class: nginx
  hosts:
    - host: airflow.rdx-works-main.extratools.works
      paths:
        - path: /
          pathType: Prefix

postgres:
  secrets:
    credentials: rdx-works-main/airflow/postgres-dev-formatted
pgbouncer:
  enabled: true
postgresql:
  enabled: false

data:
  metadataSecretName: postgres-secrets

registry:
  secretName: docker-hub-dev

workers:
  extraInitContainers:
    - name: db-migrations
      image: radixdlt/airflow-migration:{{ .Values.image.tag }}
      env:
        - name: DB_HOST
          value: "airflow-postgresql"
        - name: DB_USER
          value: "postgres"
        - name: DB_PASSWORD
          value: "postgres"
        - name: DB_NAME
          value: "token_price"