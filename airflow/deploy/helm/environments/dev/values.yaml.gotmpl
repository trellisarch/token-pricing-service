ingress:
  enabled: true
  annotations:
    kubernetes.io/ingress.class: nginx
  hosts:
    - host: airflow.rdx-works-main.extratools.works
      paths:
        - path: /
          pathType: Prefix
            backend:
              service:
                name: airflow-webserver
                port:
                  number: 8080

postgres:
  secrets:
    name: rdx-works-main/airflow/postgres-dev-formatted
docker:
  secrets:
    region: eu-west-1
    name: docker.io/radixdlt
pgbouncer:
  enabled: true
postgresql:
  enabled: false

data:
  metadataSecretName: postgres-secrets

localDB:
  enabled: false

registry:
  secretName: docker-hub-dev

workers:
  extraInitContainers:
    - name: db-migrations
      image: radixdlt/airflow-migration:sha-d82cc59
      registry:
        secretName: docker-hub-dev
      data:
        metadataSecretName: postgres-secrets
      env:
        - name: DB_HOST
          value: "airflow-postgresql"
        - name: DB_USER
          value: "postgres"
        - name: DB_PASSWORD
          value: "postgres"
        - name: DB_NAME
          value: "postgres"