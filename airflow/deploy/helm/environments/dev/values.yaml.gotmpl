ingress:
  enabled: true
  annotations:
    kubernetes.io/ingress.class: nginx
  hosts:
    - host: airflow-dev.rdx-works-main.extratools.works
      paths:
        - path: /
          pathType: Prefix
          backend:
            service:
              name: airflow-webserver
              port:
                number: 8080

docker:
  secrets:
    region: eu-west-1
    name: docker.io/radixdlt
pgbouncer:
  enabled: true
postgresql:
  enabled: false

data:
  metadataSecretName: postgres-secrets-formatted

localDB:
  enabled: false

registry:
  secretName: docker-hub-dev

secrets:
  - name: radix-charts-api-key
    secretName: radix-charts-api-key
    path: rdx-works-main-dev/airflow/radix-charts-api-key  
    secretProperty: api_key
  - name: postgres-secrets-formatted
    secretName: connection
    path: rdx-works-main-dev/airflow/postgres-dev-string  
    secretProperty: connection