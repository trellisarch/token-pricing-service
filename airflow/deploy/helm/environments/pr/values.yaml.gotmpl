docker:
  secrets:
    region: eu-west-1
    name: docker.io/radixdlt
ingress:
  enabled: true
  annotations:
    kubernetes.io/ingress.class: nginx
  hosts:
    - host: {{ .Namespace }}-airflow.rdx-works-main.extratools.works
      paths:
        - path: /
          pathType: Prefix

registry:
  secretName: docker-hub-dev
localDB:
  enabled: true