env:
  - name: "AIRFLOW__METRICS__METRICS_ALLOW_LIST"
    value: “scheduler,executor,dagrun,dag,pool,task,ti,sla"
ingress:
  enabled: true
  hosts:
    - host: airflow-service.extratools.works
      paths:
        - path: /
          pathType: ImplementationSpecific
  tls: []
  
docker:
  secrets:
    region: eu-west-1
    name: docker.io/radixdlt
pgbouncer:
  enabled: true
postgresql:
  enabled: false
data:
  metadataSecretName: postgres-secrets-formatted

localDB:
  enabled: false

registry:
  secretName: docker-hub-dev

workers:
  extraInitContainers:
    - name: db-migrations
      image: radixdlt/airflow-migration:{{ .StateValues.ci.AIRFLOW_MIGRATION_IMAGE_TAG }}
      env:
        - name: DB_URI
          valueFrom:
            secretKeyRef:
              name: db-migration-postgres-secrets-formatted
              key: connection
