replicaCount: 3

image: 
  tag: {{ .StateValues.ci.tag }}

autoscaling:
  enabled: false
  minReplicas: 1
  maxReplicas: 5
  targetCPUUtilizationPercentage: 70
  targetMemoryUtilizationPercentage: 80

metrics:
  enabled: true
  port: 5990
  serviceMonitor:
    enabled: true
    interval: 60s

resources:
  limits:
    memory: 1Gi
  requests:
    cpu: 100m
    memory: 600Mi

ingress:
  enabled: true
  hosts:
    - host: dev-token-price.extratools.works
      paths:
        - path: /
          pathType: ImplementationSpecific
  tls: []
envs:
  DB_HOST: "airflow-dev-rds-ro.rdx-works-main.internal"
  DB_NAME: "dags"
  DB_USER: "postgres"

secrets:
  - name: rds-password
    variable: "DB_PASSWORD"
    path: "rdx-works-main-dev/airflow/postgres-dev"
    secretProperty: "postgresql-password"
    secretName: "database-password"
