    path: rdx-works-main-prod/airflow/airflow-dags/mainnet-private-key
    secretProperty: private-key-bytes
  - name: account-address
    secretName: account-address
    path: rdx-works-main-prod/airflow/airflow-dags/mainnet-private-key
    secretProperty: account-address
  - name: webserver-secret-key
    secretName: webserver-secret-key
    path: rdx-works-main-prod/airflow/webserver-key
    secretProperty: webserver-secret-key
  - name: webserver-password
    secretName: webserver-password
    path: rdx-works-main-prod/airflow/webserver-login
    secretProperty: webserver_password
  - name: webserver-username
    secretName: webserver-username
    path: rdx-works-main-prod/airflow/webserver-login
    secretProperty: webserver_username
    
