secrets:
  - name: radix-charts-api-key
    secretName: radix-charts-api-key
    path: rdx-works-main-dev/airflow/api-key/radix-charts-api-key  
    secretProperty: api_key
  - name: postgres-secrets-formatted
    secretName: connection
    path: rdx-works-main-prod/airflow/postgres-prod-string  
    secretProperty: connection
  - name: db-migration-postgres-secrets-formatted
    secretName: connection
    path: rdx-works-main-prod/airflow/migrations-postgres-prod-string
    secretProperty: connection
  - name: github-token
    secretName: GITHUB_TOKEN
    path: rdx-works-main-dev/airflow/api-key/github-radixdlt 
    secretProperty: GITHUB_TOKEN
  - name: telegram-radix-devs-bot-id
    secretName: TELEGRAM_RADIX_DEVS_BOT_ID
