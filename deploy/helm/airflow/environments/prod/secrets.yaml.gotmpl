    path: rdx-works-main-dev/airflow/api-key/telegram-radixdlt 
    secretProperty: TELEGRAM_RADIX_DLT_COMBOT_API_KEY
  - name: twitter-scryptolang-api-key
    secretName: TWITTER_SCRYPTOLANG_API_KEY
    path: rdx-works-main-dev/airflow/api-key/twitter-scrypto-lang 
    secretProperty: TWITTER_SCRYPTOLANG_API_KEY
  - name: twitter-scryptolang-api-key-secret
    secretName: TWITTER_SCRYPTOLANG_API_KEY_SECRET
    path: rdx-works-main-dev/airflow/api-key/twitter-scrypto-lang 
    secretProperty: TWITTER_SCRYPTOLANG_API_KEY_SECRET
  - name: twitter-scryptolang-access-token
