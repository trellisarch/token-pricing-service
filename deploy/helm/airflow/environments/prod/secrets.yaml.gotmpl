    path: rdx-works-main-dev/airflow/api-key/twitter-scrypto-lang
    secretProperty: TWITTER_SCRYPTOLANG_ACCESS_TOKEN
  - name: twitter-scryptolang-access-token-secret
    secretName: TWITTER_SCRYPTOLANG_ACCESS_TOKEN_SECRET
    path: rdx-works-main-dev/airflow/api-key/twitter-scrypto-lang
    secretProperty: TWITTER_SCRYPTOLANG_ACCESS_TOKEN_SECRET
  - name: twitter-scryptolang-baerer-token
    secretName: TWITTER_SCRYPTOLANG_BAERER_TOKEN
    path: rdx-works-main-dev/airflow/api-key/twitter-scrypto-lang
    secretProperty: TWITTER_SCRYPTOLANG_BAERER_TOKEN
  - name: twitter-radixdlt-api-key
    secretName: TWITTER_RADIXDLT_API_KEY
    path: rdx-works-main-dev/airflow/api-key/twitter-radixdlt
    secretProperty: TWITTER_RADIXDLT_API_KEY
  - name: twitter-radixdlt-api-key-secret
    secretName: TWITTER_RADIXDLT_API_KEY_SECRET
    path: rdx-works-main-dev/airflow/api-key/twitter-radixdlt 
    secretProperty: TWITTER_RADIXDLT_API_KEY_SECRET
  - name: twitter-radixdlt-access-token
    secretName: TWITTER_RADIXDLT_ACCESS_TOKEN
    path: rdx-works-main-dev/airflow/api-key/twitter-radixdlt
    secretProperty: TWITTER_RADIXDLT_ACCESS_TOKEN
  - name: twitter-radixdlt-access-token-secret
    secretName: TWITTER_RADIXDLT_ACCESS_TOKEN_SECRET
    path: rdx-works-main-dev/airflow/api-key/twitter-radixdlt
    secretProperty: TWITTER_RADIXDLT_ACCESS_TOKEN_SECRET
  - name: twitter-radixdlt-baerer-token
