image: 
  tag: {{ .StateValues.ci.tag }}

autoscaling:
  enabled: true
  minReplicas: 1
  maxReplicas: 5
  targetCPUUtilizationPercentage: 70
  targetMemoryUtilizationPercentage: 80

metrics:
  enabled: false

envs:
  DB_HOST: "airflow-prod-rds-ro.rdx-works-main-prod.internal"
  DB_NAME: "dags"

ingress:
  enabled: true
  annotations:
  hosts:
    - host: token-price-service.radixdlt.com
      paths:
        - path: /
          pathType: Prefix
  tls: []
secrets:
  - name: rds-username
    variable: "DB_USER"
    path: "rdx-works-main-prod/airflow/postgres-prod"
    secretProperty: "postgresqlUsername"
    secretName: "database-username"
  - name: rds-password
    variable: "DB_PASSWORD"
    path: "rdx-works-main-prod/airflow/postgres-prod"
    secretProperty: "postgresql-password"
    secretName: "database-password"